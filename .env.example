SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Google OAuth 2.0 client IDs (Google Cloud Console -> APIs & Services -> Credentials)
# Create these WITHOUT Firebase:
#   1. Web application client      -> used as serverClientId on Android (required to get idToken for Supabase)
#   2. Android client               -> register your package name + SHA-1 of your signing keystore (debug + release)
#   3. iOS client                   -> register your bundle id (only needed if you ship on iOS)
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
